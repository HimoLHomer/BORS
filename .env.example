# Market AI — optional (Options → Market AI in the app, or this file for dev).
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Optional overrides (defaults work for local dev) ---

# HTTP port (3000 browser dev; Electron uses 3847)
# PORT=3000

# SQLite portfolio database (absolute path)
# BORS_DB_PATH=

# Electron / desktop user data root (%APPDATA%\BÖRS on Windows)
# BORS_USER_DATA=

# App install root (auto-detected in most setups)
# BORS_APP_ROOT=

# Static dist folder for production server
# BORS_DIST_ROOT=

# Bind address for Express (default 0.0.0.0)
# BORS_LISTEN_HOST=

# Set true to disable Vite hot reload during dev
# DISABLE_HMR=false
