{
  "name": "bors",
  "productName": "BÖRS",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first portfolio dashboard",
  "author": "BORS",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && node scripts/build-server.mjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "verify:cash": "tsx scripts/verify-cash-api.mts",
    "verify:portfolio": "tsx scripts/verify-portfolio-api.mts",
    "verify:prod": "tsx scripts/verify-production-build.mts",
    "test:release": "npm run lint && npm run verify:portfolio && npm run verify:prod",
    "rebuild:native": "npm rebuild better-sqlite3",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && node scripts/patch-electron-index.mjs && npm run electron:rebuild && electron-builder --win"
  },
  "build": {
    "appId": "fi.bors.desktop",
    "productName": "BÖRS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "data/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**",
      "dist/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
