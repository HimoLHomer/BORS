{
  "name": "bors",
  "productName": "BÖRS",
  "private": true,
  "version": "0.1.14",
  "description": "Local-first portfolio dashboard",
  "author": "BORS",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && node scripts/build-server.mjs",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "verify:cash": "tsx scripts/verify-cash-api.mts",
    "verify:portfolio": "tsx scripts/verify-portfolio-api.mts",
    "verify:market": "tsx scripts/verify-market-api.mts",
    "verify:prod": "tsx scripts/verify-production-build.mts",
    "test:unit": "vitest run",
    "test:market-news": "tsx scripts/test-market-news-ranking.mts",
    "test:portfolio-chart": "tsx scripts/test-portfolio-chart-range.mts",
    "test:portfolio-flow-return": "tsx scripts/test-portfolio-flow-return.mts",
    "test:dividend-calendar": "tsx scripts/test-dividend-calendar-projection.mts",
    "test:history-backfill": "tsx scripts/test-portfolio-history-backfill.mts",
    "test:release": "npm run lint && npm run test:unit && npm run test:market-news && npm run test:portfolio-chart && npm run test:portfolio-flow-return && npm run test:dividend-calendar && npm run test:history-backfill && npm run test:constituents && npm run verify:cash && npm run verify:portfolio && npm run verify:market && npm run verify:prod",
    "build:sp500": "tsx scripts/build-sp500-json.mts",
    "sync:constituents": "tsx scripts/sync-market-constituents.mts",
    "test:constituents": "tsx scripts/test-market-constituents.mts",
    "rebuild:native": "npm rebuild better-sqlite3",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "icons": "node scripts/generate-icons.mjs",
    "electron:dev": "npm run build && npm run icons && electron .",
    "electron:build": "npm run build && node scripts/patch-electron-index.mjs && npm run icons && npm run electron:rebuild && electron-builder --win"
  },
  "build": {
    "appId": "fi.bors.desktop",
    "productName": "BÖRS",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**",
      "dist/**"
    ],
    "publish": null,
    "afterPack": "./scripts/embed-win-icon.cjs",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "artifactName": "BORS-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": "always"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  }
}
