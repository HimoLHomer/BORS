rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email']) &&
        incoming().uid == userId;
      allow update: if isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);

      // Assets Subcollection
      match /assets/{assetId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && 
          isValidId(assetId) &&
          incoming().symbol is string &&
          incoming().quantity is number &&
          incoming().averagePrice is number;
        allow update: if isOwner(userId) &&
          incoming().diff(existing()).affectedKeys().hasAny(['quantity', 'averagePrice', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      // Transactions Subcollection
      match /transactions/{transactionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && 
          isValidId(transactionId) &&
          incoming().assetSymbol is string &&
          incoming().quantity is number;
        allow delete: if isOwner(userId);
      }
    }
  }
}
