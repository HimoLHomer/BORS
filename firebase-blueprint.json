{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Asset": {
      "title": "Asset",
      "description": "An investment asset in a portfolio",
      "type": "object",
      "properties": {
        "symbol": { "type": "string", "description": "Ticker symbol (e.g. AAPL, BTC)" },
        "displaySymbol": { "type": "string", "description": "Visual ticker symbol for UI" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["stock", "crypto", "etf", "other"] },
        "quantity": { "type": "number" },
        "averagePrice": { "type": "number", "description": "Average purchase price" },
        "currency": { "type": "string", "default": "USD" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "quantity", "averagePrice"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A buy or sell transaction",
      "type": "object",
      "properties": {
        "assetSymbol": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["assetSymbol", "type", "quantity", "price", "timestamp"]
    },
    "HistoryPoint": {
      "title": "HistoryPoint",
      "description": "Historical snapshot of total portfolio value",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "value": { "type": "number" }
      },
      "required": ["date", "value"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "User's investment assets"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "HistoryPoint",
      "description": "Historical snapshots of portfolio value"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "History of user transactions"
    }
  }
}
